# ─────────────────────────────────────────────
# Incident Commander Hub - Enterprise Configuration
# ─────────────────────────────────────────────

# --- Frontend & Backend (Supabase) ---
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbG...your-anon-key..."

# Must be set for backend JWT validation
VITE_SUPABASE_JWT_SECRET="your-jwt-secret-from-supabase-settings"


# --- Threat Intelligence ---
VITE_VIRUSTOTAL_API_KEY="your-virustotal-api-key"
VITE_ABUSEIPDB_API_KEY="your-abuseipdb-api-key"

# Optional: Set environment to production or development
NODE_ENV="development"
